# Frontend network selection for wagmi (src/config/wagmi.config.ts)
# Allowed values: hardhat | sepolia | mainnet
VITE_CHAIN=hardhat

# Local Hardhat node RPC (used when VITE_CHAIN=hardhat)
VITE_HARDHAT_RPC_URL=http://127.0.0.1:8545

# Optional custom RPC endpoints for public networks
# Used when VITE_CHAIN=sepolia or VITE_CHAIN=mainnet
VITE_SEPOLIA_RPC_URL=
VITE_MAINNET_RPC_URL=

# Optional: if you also use hardhat CLI tasks against Sepolia
# SEPOLIA_RPC_URL=
# SEPOLIA_PRIVATE_KEY=

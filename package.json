{
  "name": "tierlist-dapp-ether",
  "version": "0.0.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:contract": "hardhat compile",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "eslint . --flag unstable_native_nodejs_ts_config",
    "preview": "vite preview",
    "test:contract": "hardhat test solidity --coverage",
    "tierlist:cli": "node --experimental-strip-types scripts/tierlist-manager.ts",
    "insert:tierlist": "pnpm tierlist:cli create"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@metamask/connect-evm": "^2.1.1",
    "@tanstack/react-query": "^5.101.2",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.2.0",
    "viem": "~2.55.0",
    "wagmi": "^3.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nomicfoundation/hardhat-ignition": "^3.1.8",
    "@nomicfoundation/hardhat-ignition-viem": "^3.1.6",
    "@nomicfoundation/hardhat-verify": "^3.0.21",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "commander": "^15.0.0",
    "daisyui": "^5.6.16",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "hardhat": "^3.9.1",
    "oxfmt": "^0.58.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vite-imagetools": "^10.0.1",
    "vite-plugin-sri-gen": "^1.7.1"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11",
      "onFail": "ignore"
    },
    "runtime": {
      "name": "node",
      "version": "^24",
      "onFail": "ignore"
    }
  }
}
